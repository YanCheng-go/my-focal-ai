#!/usr/bin/env bash
# Pre-commit hook: block direct commits to main/master, run ruff on staged files
set -e

BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
    echo "ERROR: Direct commits to $BRANCH are not allowed. Use a feature branch and PR."
    exit 1
fi

STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

if [ -z "$STAGED_PY" ]; then
    exit 0
fi

echo "Running ruff check on staged files..."
uv run ruff check $STAGED_PY

echo "Running ruff format --check on staged files..."
uv run ruff format --check $STAGED_PY
