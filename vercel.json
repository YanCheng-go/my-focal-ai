{
  "outputDirectory": "static",
  "buildCommand": "",
  "framework": null,
  "cleanUrls": true,
  "ignoreCommand": "git cat-file -e ${VERCEL_GIT_PREVIOUS_SHA:-HEAD^} 2>/dev/null && git diff --quiet ${VERCEL_GIT_PREVIOUS_SHA} HEAD -- static/ api/ vercel.json || exit 1",
  "functions": {
    "api/*.py": {
      "maxDuration": 10,
      "excludeFiles": "supabase/**"
    }
  },
  "rewrites": [
    { "source": "/api/fetch-source", "destination": "/api/fetch_source" },
    { "source": "/api/resolve-url", "destination": "/api/resolve_url" },
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ]
}
