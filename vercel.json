{
  "outputDirectory": "static",
  "buildCommand": "",
  "framework": null,
  "cleanUrls": true,
  "functions": {
    "api/index.py": {
      "excludeFiles": "{tests/**,__tests__/**,**/*.test.py,**/test_*.py,docker/**,scripts/**,.github/**}"
    }
  },
  "rewrites": [
    { "source": "/admin/:path*", "destination": "/api/index" },
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/fetch",
      "schedule": "0 6 * * *"
    }
  ]
}
