{
  "outputDirectory": "static",
  "buildCommand": "",
  "framework": null,
  "cleanUrls": true,
  "functions": {
    "api/*.py": {
      "runtime": "@vercel/python@4",
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/fetch-source", "destination": "/api/fetch_source" },
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ]
}
